{
  "name": "abruno-net",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev --port 2222",
    "dev:host": "astro dev --port 2222 --host",
    "dev:sanity": "(cd sanity && npm run dev)",
    "dev:sanity:deploy": "(cd sanity && npm run deploy)",
    "sanity:install": "(cd sanity && npm install)",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format:check": "prettier --check . --plugin=prettier-plugin-astro",
    "format": "prettier --write . --plugin=prettier-plugin-astro",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.4.0",
    "@astrojs/check": "^0.7.0",
    "@astrojs/partytown": "^2.1.0",
    "@astrojs/sitemap": "^3.1.5",
    "@astrojs/tailwind": "^5.1.0",
    "@sanity/astro": "^3.0.0",
    "@sanity/client": "^6.15.20",
    "@types/alpinejs": "^3.13.10",
    "alpinejs": "^3.13.10",
    "astro": "^4.9.2",
    "date-fns": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@typescript-eslint/parser": "^7.8.0",
    "astro-eslint-parser": "^0.16.3",
    "astro-portabletext": "^0.10.0",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^0.33.1",
    "postcss-nesting": "^12.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.14"
  },
  "engines": {
    "node": "20.x"
  }
}
