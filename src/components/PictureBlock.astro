---
import { urlForImage } from "@utils/urlForImage";

const { image, alt } = Astro.props;
const url = urlForImage(image).width(1720).url();
const webpUrl = urlForImage(image).format("webp").width(1720).url();
---

<picture>
  <source srcset={webpUrl} type="image/webp" />
  <img src={url} alt={alt} />
</picture>
