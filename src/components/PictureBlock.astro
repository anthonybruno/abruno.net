---
import { urlForImage } from "@utils/urlForImage";

const { image, alt } = Astro.props;
const url = urlForImage(image).url();
const webpUrl = urlForImage(image).format("webp").url();
---

<picture>
  <source srcset={webpUrl} type="image/webp" />
  <img
    src={url}
    alt={alt}
    class="aspect-[283/192] w-full max-w-full bg-neutral-100 transition-opacity duration-[4000ms] dark:opacity-70 hover:dark:opacity-100"
    width="566"
    height="384"
  />
</picture>
