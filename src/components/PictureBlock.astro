---
import { urlForImage } from "@utils/urlForImage";

const { image, alt } = Astro.props;
const url = urlForImage(image).width(1135).url();
const webpUrl = urlForImage(image).format("webp").width(1135).url();
---

<picture>
  <source srcset={webpUrl} type="image/webp" />
  <img
    src={url}
    alt={alt}
    class="aspect-[283/192] w-full max-w-full bg-[#D9D9D9]"
    width="566"
    height="384"
  />
</picture>
