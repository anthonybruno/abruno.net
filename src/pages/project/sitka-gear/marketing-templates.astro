---
import GlobalLayout from "@layouts/GlobalLayout.astro";
import PageTitle from "@components/PageTitle.astro";
import TextBlock from "@components/TextBlock.astro";
import PreviewNotice from "@components/PreviewNotice.astro";

const url = "https://abruno-sitka-static.vercel.app";
---

<GlobalLayout
  title="Marketing Templates • Sitka Gear"
  back={true}
  backLabel="Back to Case Study"
  backRoute="./"
>
  <div class="space-y-14">
    <PageTitle>Sitka Gear</PageTitle>
    <PreviewNotice />
    <TextBlock>
      <h2>Marketing Templates</h2>
      <ul>
        <li>
          <a href={`${url}/index.html`} target="_blank"> Homepage </a>
        </li>
        <li>
          <a href={`${url}/gear.html`} target="_blank">
            Products &ndash; Gear
          </a>
        </li>
        <li>
          <a href={`${url}/product/index.html`} target="_blank">
            Products &ndash; Single Product
          </a>
        </li>
        <li>
          <a href={`${url}/activity/scenario.html`} target="_blank">
            Activity &ndash; Scenario
          </a>
        </li>
        <li>
          <a href={`${url}/activity/overview.html`} target="_blank">
            Activity &ndash; Overview
          </a>
        </li>
        <li>
          <a href={`${url}/activity/detail.html`} target="_blank">
            Activity &ndash; Detail
          </a>
        </li>
        <li>
          <a href={`${url}/hunting-life/index.html`} target="_blank">
            Hunting Life &ndash; Index
          </a>
        </li>
        <li>
          <a href={`${url}/hunting-life/category.html`} target="_blank">
            Hunting Life &ndash; Category
          </a>
        </li>
        <li>
          <a href={`${url}/hunting-life/article.html`} target="_blank">
            Hunting Life &ndash; Article
          </a>
        </li>
        <li>
          <a href={`${url}/search/products.html`} target="_blank">
            Search Result &ndash; Products
          </a>
        </li>
        <li>
          <a href={`${url}/search/activities.html`} target="_blank">
            Search Result &ndash; Activities
          </a>
        </li>
        <li>
          <a href={`${url}/search/stories-videos.html`} target="_blank">
            Search Result – Stories &amp; Videos
          </a>
        </li>
      </ul>
    </TextBlock>
  </div>
</GlobalLayout>
