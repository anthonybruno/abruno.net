---
import { getHome } from "@utils/api";
import { type projectNavItem } from "@utils/types";

import GlobalLayout from "@layouts/GlobalLayout.astro";
import PageTitle from "@components/PageTitle.astro";
import ProjectList from "@components/ProjectList.astro";
import PortableText from "@components/PortableText.astro";
import TextBlock from "@components/TextBlock.astro";
import Currently from "@components/Currently.html";

interface Props {
  bio: string;
  projectNavItems: projectNavItem[];
  contactItems: contactItem[];
}

interface contactItem {
  label: string;
  url: string;
}

const data = await getHome();
const { bio, projectNavItems, contactItems } = data as Props;
---

<GlobalLayout>
  <div class="space-y-16">
    <PageTitle>Anthony Bruno</PageTitle>
    <TextBlock>
      <PortableText value={bio} />
    </TextBlock>

    <ProjectList title="Projects" items={projectNavItems} />

    <div>
      <h2 class="pb-8">Get in touch</h2>
      <ul class="space-y-4">
        {
          contactItems.map((item: contactItem) => (
            <li>
              <a
                class="transition-opacity after:content-['_↗'] hover:text-blue-500"
                href={item.url}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <Currently client:load />
  </div>
</GlobalLayout>
